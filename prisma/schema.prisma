generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  password         String?
  googleId         String?  @unique
  personalEntities Json?
  ideaConfigs      Json?
  noteCategories   Json?
  theme            String?   @default("default")
  customTheme      Json?
  themeAdjustments Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ideasOwned         Idea[]        @relation("IdeasOwned")
  ideasCollaborating Idea[]        @relation("IdeaCollaborators")
  contactsOwned      Contact[]     @relation("ContactsOwned")
  entitiesOwned      Entity[]      @relation("EntitiesOwned")
  interactions       Interaction[]
  invitationsSent    Invitation[]  @relation("InvitationsSent")
  notesCreated       Note[]        @relation("NotesCreated")
  taggedInNotes      Note[]        @relation("TaggedUsers")
  comments           Comment[]
  dailyTodos         DailyTodo[]
  assignedTasks      DailyTodo[] @relation("TaskAssignee")
  completedTasks     DailyTodo[] @relation("TaskCompleter")
  reminderImages     ReminderImage[]
}

model DailyTodo {
  id          String    @id @default(cuid())
  text        String
  completed   Boolean   @default(false)
  isUrgent    Boolean   @default(false)
  sortOrder   Int       @default(0)
  date        DateTime? // null = floating/backburner task
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Kanban / Idea fields
  status       String?   // Not Started, Working, Done, Archived
  dueDate      String?
  assigneeId   String?
  assignee     User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  comments     String?
  originNoteId String?
  timeBlock    String?   // morning, afternoon, evening
  activityNoteIds Json?  // IDs of auto-created activity log notes

  completedById String?
  completedBy   User?   @relation("TaskCompleter", fields: [completedById], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  ideaId String?
  idea   Idea?   @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  parentId String?
  parent   DailyTodo?  @relation("TodoSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  children DailyTodo[] @relation("TodoSubtasks")

  @@index([userId, date])
  @@index([ideaId])
}

model Idea {
  id               String   @id @default(cuid())
  title            String
  type             String
  entity           String
  status           String
  priority         Int
  oneLiner         String?
  problem          String?
  solution         String?
  targetCustomer   String?
  businessModel    String?
  risks            String?
  nextSteps        String?
  descriptionColor String?
  activityColor    String?
  linkedContactIds String   @default("[]")
  tags             String   @default("[]")
  todos            String   @default("[]")
  links            String   @default("[]")
  customNoteCategories String @default("[]")

  isFavorite       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation("IdeasOwned", fields: [ownerId], references: [id])

  collaborators User[] @relation("IdeaCollaborators")

  invitations Invitation[]
  notes       Note[]
  dailyTodos  DailyTodo[]

  parentId String?
  parent   Idea?   @relation("IdeaSubIdeas", fields: [parentId], references: [id], onDelete: SetNull)
  children Idea[]  @relation("IdeaSubIdeas")
  attachments FileAttachment[]
}

model FileAttachment {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileName    String
  fileType    String
  fileSize    Int
  content     String   // Base64 encoded file
  createdAt   DateTime @default(now())

  ideaId      String
  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}

model FileAttachmentChunk {
  id         String   @id @default(cuid())
  uploadId   String
  chunkIndex Int
  content    String   // Base64 chunk
  createdAt  DateTime @default(now())

  @@unique([uploadId, chunkIndex])
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName    String?
  lastName     String?
  fullName     String?
  email        String?
  phone        String?
  company      String?
  org          String?
  role         String?
  country      String?
  linkedinUrl  String?
  instagramUrl String?
  twitterUrl   String?
  substackUrl  String?
  isWhatsApp   Boolean @default(false)
  tags         Json?
  linkedEntityIds Json?
  notes        String?
  isPrivateDetails Boolean @default(false)
  relationshipStrength Int @default(1)
  linkedIdeaIds String @default("[]")

  ownerId String?
  owner   User?   @relation("ContactsOwned", fields: [ownerId], references: [id])

  taggedInNotes Note[] @relation("TaggedContacts")
  associatedNotes Note[] @relation("NoteToContact")
}

model Note {
  id         String   @id @default(cuid())
  content    String?
  categories String   @default("[]")
  isPinned   Boolean  @default(false)
  isHidden   Boolean  @default(false)
  location   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdById String
  createdBy   String?
  author      User    @relation("NotesCreated", fields: [createdById], references: [id])

  ideaId      String?
  idea        Idea?    @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  contactId   String?
  contact     Contact? @relation("NoteToContact", fields: [contactId], references: [id], onDelete: Cascade)

  taggedContacts Contact[] @relation("TaggedContacts")
  taggedUsers    User[]    @relation("TaggedUsers")
  taggedEntities Entity[]  @relation("TaggedEntities")
  imageUrl    String?
  intent      String?
  comments    Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Interaction {
  id        String    @id @default(cuid())
  type      String?
  date      DateTime?
  outcome   String?
  nextAction String?
  nextActionDate DateTime?
  relatedIdeaId String?
  relatedContactId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  type      String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId String
  sender   User   @relation("InvitationsSent", fields: [senderId], references: [id])

  ideaId String?
  idea   Idea?   @relation(fields: [ideaId], references: [id])
  message String?
}

model ReminderImage {
  id        String   @id @default(cuid())
  imageData String   // base64 data URL
  fileType  String?
  fileName  String?
  fileSize  Int?
  caption   String?
  rotation  Int      @default(0)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Entity {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String?
  website     String?
  linkedinUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User @relation("EntitiesOwned", fields: [ownerId], references: [id])

  taggedInNotes Note[] @relation("TaggedEntities")
}
